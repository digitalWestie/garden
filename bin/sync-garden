#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

SOURCE_DIR="${GARDEN_OBSIDIAN_SOURCE:-$HOME/obsidian-main}"
DEST_DIR="${PROJECT_ROOT}/src/garden"
RULES_FILE="${PROJECT_ROOT}/.garden-include"
TRANSFORM_RB="${SCRIPT_DIR}/_garden_markdown_transform.rb"

DRY_RUN=0
VERBOSE=0
DELETE=1
GARDEN_PAGE="${PROJECT_ROOT}/src/garden.md"

usage() {
  cat <<'EOF'
Sync selected Obsidian content into Bridgetown garden section.

Usage:
  bin/sync-garden [--dry-run] [--verbose] [--no-delete] [--source PATH] [--rules PATH]

Options:
  --dry-run      Show what would change without writing files
  --verbose      Print full rsync output
  --no-delete    Do not remove files in destination that no longer match rules
  --source PATH  Override source vault directory (default: ~/obsidian-main)
  --rules PATH   Override include rules file (default: .garden-include)
  -h, --help     Show this help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --verbose)
      VERBOSE=1
      shift
      ;;
    --no-delete)
      DELETE=0
      shift
      ;;
    --source)
      SOURCE_DIR="${2:-}"
      shift 2
      ;;
    --rules)
      RULES_FILE="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ -z "${SOURCE_DIR}" ]]; then
  echo "Source directory cannot be empty." >&2
  exit 1
fi

if [[ ! -d "${SOURCE_DIR}" ]]; then
  echo "Source vault directory not found: ${SOURCE_DIR}" >&2
  exit 1
fi

if [[ ! -f "${RULES_FILE}" ]]; then
  echo "Rules file not found: ${RULES_FILE}" >&2
  exit 1
fi

if [[ ! -f "${TRANSFORM_RB}" ]]; then
  echo "Ruby transform not found: ${TRANSFORM_RB}" >&2
  exit 1
fi

mkdir -p "${DEST_DIR}"

FILTER_FILE="$(mktemp)"
cleanup() {
  rm -f "${FILTER_FILE}"
}
trap cleanup EXIT

printf "+ */\n" >> "${FILTER_FILE}"

while IFS= read -r raw_line || [[ -n "${raw_line}" ]]; do
  line="${raw_line#"${raw_line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  [[ -z "${line}" ]] && continue
  [[ "${line}" == \#* ]] && continue

  if [[ "${line}" == \!* ]]; then
    pattern="${line:1}"
    [[ -z "${pattern}" ]] && continue
    printf -- "- %s\n" "${pattern}" >> "${FILTER_FILE}"
  else
    printf -- "+ %s\n" "${line}" >> "${FILTER_FILE}"
  fi
done < "${RULES_FILE}"

printf -- "- *\n" >> "${FILTER_FILE}"

RSYNC_FLAGS=(-a --prune-empty-dirs --itemize-changes --human-readable)
RSYNC_FLAGS+=(--filter=". ${FILTER_FILE}")

if [[ "${DELETE}" -eq 1 ]]; then
  RSYNC_FLAGS+=(--delete)
fi

if [[ "${DRY_RUN}" -eq 1 ]]; then
  RSYNC_FLAGS+=(--dry-run)
fi

if [[ "${VERBOSE}" -eq 1 ]]; then
  RSYNC_FLAGS+=(-v)
else
  RSYNC_FLAGS+=(--info=NAME,STATS)
fi

echo "Syncing Obsidian content:"
echo "  source: ${SOURCE_DIR}"
echo "  destination: ${DEST_DIR}"
echo "  rules: ${RULES_FILE}"
echo

rsync "${RSYNC_FLAGS[@]}" "${SOURCE_DIR}/" "${DEST_DIR}/"

if [[ "${DRY_RUN}" -eq 0 ]]; then
  (cd "${PROJECT_ROOT}" && bundle exec ruby "${TRANSFORM_RB}" "${DEST_DIR}")

  front_matterized=0
  while IFS= read -r -d '' file; do
    base="$(basename "${file}")"
    [[ "${base}" == "index.md" ]] && continue

    first_line=""
    IFS= read -r first_line < "${file}" || true
    if [[ "${first_line}" == "---" ]]; then
      continue
    fi

    base_name="$(basename "${file}" .md)"
    title="${base_name//_/ }"
    title="${title//-/ }"
    tmp_file="$(mktemp)"

    {
      printf -- "---\n"
      printf -- "layout: obsidian\n"
      printf -- "title: %s\n" "${title}"
      printf -- "---\n\n"
      cat "${file}"
    } > "${tmp_file}"

    mv "${tmp_file}" "${file}"
    front_matterized=$((front_matterized + 1))
  done < <(find "${DEST_DIR}" -type f -name '*.md' -print0)

  if [[ ! -f "${GARDEN_PAGE}" ]]; then
    echo "Garden page not found: ${GARDEN_PAGE}" >&2
    exit 1
  fi

  while IFS= read -r -d '' dir; do
    [[ -d "${dir}" ]] || continue
    folder_name="$(basename "${dir}")"
    title="${folder_name//_/ }"
    title="${title//-/ }"

    tmp_index="$(mktemp)"
    {
      printf -- "---\n"
      printf -- "layout: page\n"
      printf -- "title: %s\n" "${title}"
      printf -- "---\n\n"
      printf -- "# %s\n\n" "${title}"
      printf -- "Notes in this folder:\n\n"
    } > "${tmp_index}"

    any_note=0
    while IFS= read -r -d '' note; do
      any_note=1
      rel="${note#$dir/}"
      rel="${rel%.md}"
      display="${rel//\// / }"
      display="${display//_/ }"
      display="${display//-/ }"
      encoded="${rel// /%20}"
      printf -- "- [%s](./%s/)\n" "${display}" "${encoded}"
    done < <(find "${dir}" -type f -name '*.md' ! -path "${dir}/index.md" -print0 | sort -z) >> "${tmp_index}"

    if [[ "${any_note}" -eq 0 ]]; then
      printf -- "_No notes in this folder._\n" >> "${tmp_index}"
    fi

    mv "${tmp_index}" "${dir}/index.md"
  done < <(find "${DEST_DIR}" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

  tmp_folders="$(mktemp)"
  tmp_root="$(mktemp)"
  folder_count=0
  root_count=0

  while IFS= read -r -d '' dir; do
    [[ -d "${dir}" ]] || continue
    if ! find "${dir}" -type f -name '*.md' ! -path "${dir}/index.md" -print -quit | grep -q .; then
      continue
    fi
    name="$(basename "${dir}")"
    enc="${name// /%20}"
    printf -- '- [%s](./garden/%s/)\n' "${name}" "${enc}" >> "${tmp_folders}"
    folder_count=$((folder_count + 1))
  done < <(find "${DEST_DIR}" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

  while IFS= read -r -d '' file; do
    base_name="$(basename "${file}" .md)"
    display="${base_name//_/ }"
    display="${display//-/ }"
    enc="${base_name// /%20}"
    printf -- '- [%s](./garden/%s/)\n' "${display}" "${enc}" >> "${tmp_root}"
    root_count=$((root_count + 1))
  done < <(find "${DEST_DIR}" -maxdepth 1 -type f -name '*.md' -print0 | sort -z)

  tmp_garden="$(mktemp)"
  awk '
    BEGIN {in_block=0}
    /^<!-- BEGIN:GARDEN_LINKS -->$/ {in_block=1; next}
    /^<!-- END:GARDEN_LINKS -->$/ {in_block=0; next}
    in_block==1 {next}
    {print}
  ' "${GARDEN_PAGE}" > "${tmp_garden}"

  {
    cat "${tmp_garden}"
    printf "\n<!-- BEGIN:GARDEN_LINKS -->\n"
    if [[ "${folder_count}" -eq 0 ]] && [[ "${root_count}" -eq 0 ]]; then
      printf "_No synced markdown notes found yet._\n"
    else
      if [[ "${folder_count}" -gt 0 ]]; then
        cat "${tmp_folders}"
      fi
      if [[ "${root_count}" -gt 0 ]]; then
        printf "\n### Root notes\n\n"
        cat "${tmp_root}"
      fi
    fi
    printf "<!-- END:GARDEN_LINKS -->\n"
  } > "${tmp_garden}.new"

  mv "${tmp_garden}.new" "${GARDEN_PAGE}"
  rm -f "${tmp_folders}" "${tmp_root}" "${tmp_garden}" "${DEST_DIR}/garden-index.md" "${DEST_DIR}/notes-index.md"
fi

echo
if [[ "${DRY_RUN}" -eq 1 ]]; then
  echo "Dry run complete. No files were changed."
else
  echo "Sync complete."
  echo "Front matter added to ${front_matterized} markdown file(s) (excluding index.md)."
  echo "Updated garden links on: ${GARDEN_PAGE}"
fi
